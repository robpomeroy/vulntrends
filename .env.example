# VulnTrends local secrets
#
# Copy this file to `.env` and fill in your real values. The `.env`
# file is gitignored — your secrets never leave your machine.

# ── Data pipeline keys ──────────────────────────────────────────────

# NVD/CVE API key — request at https://nvd.nist.gov/developers/request-an-api-key
# Without this key the NVD source is limited to 1 request per 6 seconds,
# which makes the data build take 10+ minutes.
NVD_API_KEY=

# Microsoft CVRF API key — optional. The MSRC API is publicly accessible
# (Microsoft dropped the registration requirement in Feb 2021) and the
# pipeline will work without a key, just at the default rate limit
# (~10 requests/min). With a key the limit is higher. If you need
# faster refreshes, the only known route is to email msrcapi@microsoft.com
# with a brief description of what you're building; there is no
# automated self-serve sign-up.
MSRC_API_KEY=

# Pipeline resilience: the data pipeline aborts before aggregation if
# more than this many sources fail *with no cached data from a previous
# run*. The default of 2 is generous: with 10 sources, losing 2 is
# acceptable (the other 8 carry the run). Losing 3+ usually means a
# systemic problem (network down, NVD API key expired, DNS broken)
# that should be investigated rather than deployed.
#
# Sources that fail but have cached data are NOT counted here — they
# contribute stale-but-useful data to the run, and a stderr warning
# surfaces which sources were stale so you can spot a degrading
# situation before it becomes a real problem.
MAX_SOURCE_FAILURES=2

# ── Web host deployment (for `npm run publish`) ───────────────────
#
# These are used by scripts/publish.ts to rsync the built site to
# the Namecheap web host. The SSH key must have no passphrase
# (the Synology scheduled task runs unattended).

# Hostname or IP of the web host
DEPLOY_HOST=

# Custom SSH port (default 22)
DEPLOY_PORT=22

# SSH user account on the web host
DEPLOY_USER=

# Path to the SSH private key (no passphrase)
DEPLOY_KEY=

# Web root path on the host for the production site
DEPLOY_PROD_PATH=

# Web root path on the host for the staging site
DEPLOY_STAGING_PATH=

# ── Site URL (drives sitemap, robots.txt, og:url, og:image, canonical) ─
#
# The publish script passes `astro build --site <URL>`, which overrides
# the `site` value in astro.config.mjs for that build. This is what
# makes the staging deploy ship a robots.txt pointing at the staging
# sitemap, not the production one. Defaults shown — override only if
# staging moves to a different subdomain.
#
# SITE_URL is used for `npm run publish` (production).
# SITE_URL_STAGING is used for `npm run publish:staging`.
SITE_URL=https://vulntrends.org
SITE_URL_STAGING=https://staging.vulntrends.org
