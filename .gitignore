# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Vulnerability data — regenerated as required when publishing.
# (npm run publish). Locally we keep our own copies (regenerated via
# `npm run data:build` or `npm run data:sample`).
src/data/*
!src/data/.gitkeep
public/data/*
!public/data/.gitkeep

# Snapshot archive — populated by `npm run data:archive` (called by publish).
# Local staging area only; replication to a backup target is done by
# scripts/publish.ts via the `ARCHIVE_RSYNC_TARGET` env var (rsync to
# a user@host:/path or a local /path). The archive is NOT committed to
# Git because production (Synology) has read-only Git access — see
# docs/plans/2026-07-22-improvement-plan.md (C2) for the rationale.
data-archive/*
!data-archive/.gitkeep

# Ignore logs
logs/*
!logs/.gitkeep
