# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Vulnerability data — regenerated daily by the Synology NAS scheduled task
# (npm run publish). Locally we keep our own copies (regenerated via
# `npm run data:build` or `npm run data:sample`).
src/data/*
!src/data/.gitkeep

# Snapshot archive — populated by `npm run data:archive` (called by publish).
# Committed to the repo as the Tier-2 retention layer (see docs/plans/2026-07-22-improvement-plan.md).
# Use Git LFS if file sizes grow large.
data-archive/*/raw/
data-archive/*/meta.json
!data-archive/.gitkeep
!data-archive/manifest.json

# Ignore logs
logs/*
!logs/.gitkeep
