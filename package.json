{
  "name": "vulntrends",
  "type": "module",
  "version": "1.1.0",
  "description": "Tracking trends in vulnerability patching across major software manufacturers",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "data:build": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/pipeline/index.ts && tsx --env-file-if-exists=.env scripts/aggregate.ts",
    "data:validate": "node scripts/check-platform.mjs && tsx scripts/validate.ts",
    "data:sample": "node scripts/check-platform.mjs && tsx scripts/generate-sample-data.ts",
    "publish": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts",
    "publish:staging": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --staging",
    "publish:dry-run": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --dry-run",
    "publish:staging:dry-run": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --staging --dry-run",
    "publish:data": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --only=data:build",
    "publish:validate": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --only=data:validate",
    "publish:build": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --only=data:build,data:validate,build",
    "publish:upload": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --only=rsync",
    "publish:upload:dry-run": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --only=rsync --dry-run",
    "publish:skip-data": "node scripts/check-platform.mjs && tsx --env-file-if-exists=.env scripts/publish.ts --skip=data:build"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "d3": "^7.9.0",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/d3": "^7.4.3",
    "@types/node": "^26.1.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
