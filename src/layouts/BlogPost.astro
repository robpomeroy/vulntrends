---
/**
 * Blog post layout — wraps the site-wide Dashboard layout and adds
 * article-specific chrome (title, dates, tags, back-link) plus prose
 * styling for the rendered Markdown body.
 *
 * Prose is styled with Tailwind utilities rather than the
 * @tailwindcss/typography plugin, to keep the dependency surface at
 * zero and to respect the dark-first palette tokens defined in
 * src/styles/global.css.
 */

import DashboardLayout from '@/layouts/Dashboard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, updatedDate, tags, heroImage, heroImageAlt } =
  entry.data;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });

const isoDate = pubDate.toISOString();

/**
 * Resolve a public-rooted hero image path. The frontmatter stores the
 * image as either a `~/public/...` repo path or an absolute `/...` path
 * (served from the `public/` directory by Astro). Anything else is
 * ignored — the post header simply skips the hero in that case.
 */
const heroSrc = (() => {
  if (!heroImage) return null;

  const normalised = heroImage
    .replace(/^~\/public\//, '/')
    .replace(/^~\//, '/')
    .replace(/^\.\.\/\.\.\/public\//, '/');

  return normalised.startsWith('/') && !normalised.startsWith('//') ? normalised : null;
})();
---

<DashboardLayout>
  <article class="max-w-3xl mx-auto">
    <a href="/blog/" class="inline-block mb-6 text-sm text-vt-text-muted hover:text-vt-accent transition-colors">
      ← Back to blog
    </a>

    <header class="mb-8 border-b border-vt-border pb-6">
      {heroSrc && (
        <a href={heroSrc} target="_blank" rel="noopener noreferrer" class="block mb-6">
          <img
            src={heroSrc}
            alt={heroImageAlt ?? ''}
            loading="eager"
            decoding="async"
            width="1200"
            height="675"
            class="w-full h-auto aspect-video object-cover rounded border border-vt-border"
          />
        </a>
      )}
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight m-0 mb-3">{title}</h1>
      <p class="text-vt-text-secondary text-lg mb-4">{description}</p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-vt-text-muted">
        <time datetime={isoDate}>{formatDate(pubDate)}</time>
        {updatedDate && (
          <span>
            (updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>)
          </span>
        )}
        {tags.length > 0 && (
          <ul class="flex flex-wrap gap-2 list-none m-0 p-0">
            {tags.map((tag) => (
              <li class="px-2 py-0.5 rounded bg-vt-bg-tertiary text-vt-text-secondary text-xs">{tag}</li>
            ))}
          </ul>
        )}
      </div>
    </header>

    <div class="prose-vt">
      <slot />
    </div>
  </article>
</DashboardLayout>

<style is:global>
  /* Prose styling for .prose-vt — dark-first, no typography plugin.
     `is:global` makes the whole stylesheet global, so descendant
     selectors target the rendered Markdown body (which is not scoped). */
  .prose-vt {
    color: var(--vt-text-secondary);
    line-height: 1.7;
  }

  .prose-vt > * + * {
    margin-top: 1.25em;
  }

  .prose-vt h2 {
    color: var(--vt-text-primary);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2em;
    line-height: 1.3;
  }

  .prose-vt h3 {
    color: var(--vt-text-primary);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.75em;
    line-height: 1.3;
  }

  .prose-vt h4 {
    color: var(--vt-text-primary);
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 1.5em;
  }

  .prose-vt a {
    color: var(--vt-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose-vt a:hover {
    color: #7dd3fc;
  }

  .prose-vt strong {
    color: var(--vt-text-primary);
    font-weight: 600;
  }

  .prose-vt ul,
  .prose-vt ol {
    padding-left: 1.5rem;
  }

  .prose-vt ul {
    list-style: disc;
  }

  .prose-vt ol {
    list-style: decimal;
  }

  .prose-vt li {
    margin-top: 0.4em;
  }

  .prose-vt li::marker {
    color: var(--vt-text-muted);
  }

  .prose-vt blockquote {
    border-left: 3px solid var(--vt-border);
    padding-left: 1rem;
    color: var(--vt-text-muted);
    font-style: italic;
  }

  .prose-vt code {
    background-color: var(--vt-bg-tertiary);
    border-radius: var(--vt-radius-sm);
    padding: 0.15em 0.4em;
    font-size: 0.875em;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  .prose-vt pre {
    background-color: var(--vt-bg-secondary);
    border: 1px solid var(--vt-border);
    border-radius: var(--vt-radius);
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.875rem;
  }

  .prose-vt pre code {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
  }

  .prose-vt hr {
    border: none;
    border-top: 1px solid var(--vt-border);
    margin-top: 2em;
  }

  .prose-vt img {
    border-radius: var(--vt-radius);
    border: 1px solid var(--vt-border);
  }
</style>
