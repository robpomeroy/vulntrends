---
/**
 * Dashboard layout — full-page shell with header, main content, and footer.
 */

import '@/styles/global.css';
// Favicons live in src/assets/ so Astro/Vite hashes their filenames on
// build (e.g. /_astro/favicon.a1b2c3.svg). The hash changes whenever the
// file changes, which busts LiteSpeed and browser caches automatically —
// no manual ?v= query string, and no need to purge the LiteSpeed cache
// from cPanel. Assets under public/ are copied verbatim (no content hash), so
// the URL won’t change automatically when the favicon changes.
import faviconSvg from '@/assets/favicon.svg?url';
import faviconIco from '@/assets/favicon.ico?url';
// og-image.jpg stays under public/ because content hashes don't help a
// social-card URL: crawlers fetch it once on share and the URL must be
// stable across deploys for it to be re-cached by social platforms.
import ogImage from '/og-image.jpg?url';

interface Props {
  lastUpdated?: string;
}

const { lastUpdated } = Astro.props;
const pathname = Astro.url.pathname;

const isAboutActive = pathname === '/about/' || pathname.startsWith('/about/');
const isBlogActive = pathname === '/blog/' || pathname.startsWith('/blog/');

const formattedDate =
  lastUpdated && !Number.isNaN(Date.parse(lastUpdated))
    ? new Date(lastUpdated).toLocaleString('en-GB', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
      })
    : null;

// Plausible Analytics — built into the page at build time. The script
// tag is either emitted or absent; there is no runtime injection and no
// client-side decision about whether to load analytics.
//
// Three guards, all required:
//   1. PUBLIC_PLAUSIBLE_ENABLED === 'true' — opt-in via .env, defaults
//      off so fresh clones and dev machines don't emit the script.
//   2. !isStaging — Astro.site.hostname is set by `astro build --site`
//      in scripts/publish.ts. For staging deploys the hostname starts
//      with `staging.`, so the script is auto-excluded regardless of
//      the boolean. This is what keeps a shared .env from accidentally
//      shipping analytics to staging.
//   3. A script URL is configured — prevents a broken `<script src="">`
//      tag if someone toggles the boolean on but forgets the URL.
const plausibleScriptUrl = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_URL?.trim();
const plausibleDataDomain = import.meta.env.PUBLIC_PLAUSIBLE_DATA_DOMAIN?.trim() || 'vulntrends.org';
const isStaging = Astro.site.hostname.startsWith('staging.');
const plausibleEnabled =
  import.meta.env.PUBLIC_PLAUSIBLE_ENABLED === 'true' && !isStaging && !!plausibleScriptUrl;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={faviconSvg} />
    <link rel="icon" href={faviconIco} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>VulnTrends — Vulnerability Patching Trends</title>
    <meta
      name="description"
      content="Tracking trends in vulnerability patching across major software manufacturers. An open-source, data-driven dashboard."
    />
    <meta property="og:title" content="VulnTrends — Vulnerability Patching Trends" />
    <meta
      property="og:description"
      content="Tracking trends in vulnerability patching across major software manufacturers."
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="VulnTrends dashboard preview — discovered and backlog charts" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:site_name" content="VulnTrends" />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:image:alt" content="VulnTrends dashboard preview — discovered and backlog charts" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    {plausibleEnabled && (
      <script defer data-domain={plausibleDataDomain} src={plausibleScriptUrl}></script>
    )}
  </head>
  <body>
    <header class="bg-vt-bg-secondary border-b border-vt-border py-6">
      <div class="w-full max-w-[1400px] mx-auto px-6 flex items-start justify-between gap-4 flex-wrap">
        <div class="min-w-0">
          <nav aria-label="Primary" class="mb-4">
            <ul class="list-none m-0 p-0 flex items-center gap-5 text-sm">
              <li>
                <a
                  href="/about/"
                  class={`pb-1 border-b transition-colors ${
                    isAboutActive
                      ? 'text-vt-text-primary border-vt-accent'
                      : 'text-vt-text-muted border-transparent hover:text-vt-text-primary'
                  }`}
                  aria-current={isAboutActive ? 'page' : undefined}
                >
                  About
                </a>
              </li>
              <li>
                <a
                  href="/blog/"
                  class={`pb-1 border-b transition-colors ${
                    isBlogActive
                      ? 'text-vt-text-primary border-vt-accent'
                      : 'text-vt-text-muted border-transparent hover:text-vt-text-primary'
                  }`}
                  aria-current={isBlogActive ? 'page' : undefined}
                >
                  Blog
                </a>
              </li>
            </ul>
          </nav>
          <h1 class="text-3xl font-bold tracking-tight m-0">
            <a
              href="/"
              class="inline-flex items-center gap-3 text-vt-text-primary hover:text-vt-text-primary focus-visible:outline-2 focus-visible:outline-vt-accent focus-visible:rounded-sm"
            >
              <img src={faviconSvg} alt="" class="w-8 h-8 shrink-0" />
              <span>Vuln<span class="text-vt-accent">Trends</span></span>
            </a>
          </h1>
          <p class="text-vt-text-muted text-sm mt-1 max-w-2xl">
            Tracking trends in vulnerability patching across major software manufacturers
          </p>
        </div>
        {formattedDate && (
          <div class="text-right shrink-0">
            <span class="block text-xs uppercase tracking-wide text-vt-text-muted">Last updated</span>
            <time class="text-sm text-vt-text-secondary" datetime={lastUpdated}>{formattedDate}</time>
          </div>
        )}
      </div>
    </header>

    <main class="flex-1 py-8">
      <div class="w-full max-w-[1400px] mx-auto px-6">
        <slot />
      </div>
    </main>

    <footer class="bg-vt-bg-secondary border-t border-vt-border py-8 mt-8">
      <div class="w-full max-w-[1400px] mx-auto px-6 grid grid-cols-1 gap-8 md:grid-cols-[2fr_1fr_1fr]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-vt-text-muted mb-3">VulnTrends</p>
          <p class="text-sm text-vt-text-secondary">
            Open-source data on vulnerability patching trends.
          </p>
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-vt-text-muted mb-3">Data sources</p>
          <ul class="list-none text-sm space-y-1">
            <li><a href="https://www.mozilla.org/en-US/security/advisories/">Mozilla MFSA</a></li>
            <li><a href="https://api.msrc.microsoft.com/cvrf/v3.0/">Microsoft MSRC</a></li>
            <li><a href="https://bugs.chromium.org/p/project-zero/">Project Zero</a></li>
            <li><a href="https://services.nvd.nist.gov/rest/json/cves/2.0">NVD/CVE</a></li>
            <li><a href="https://chromereleases.googleblog.com/">Chrome Releases</a></li>
            <li><a href="https://support.apple.com/en-us/HT201222">Apple Security</a></li>
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-vt-text-muted mb-3">Project</p>
          <ul class="list-none text-sm space-y-1">
            <li><a href="/about/">About &amp; methodology</a></li>
            <li><a href="/blog/">Blog</a></li>
            <li><a href="https://github.com/robpomeroy/vulntrends">GitHub</a></li>
            <li>MIT Licensed</li>
          </ul>
        </div>
      </div>
    </footer>
  </body>
</html>
