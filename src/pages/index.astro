---
import Dashboard from '@/components/Dashboard.svelte';
import DashboardLayout from '@/layouts/Dashboard.astro';
import { loadDashboardData } from '@/lib/load';

const data = await loadDashboardData();
---

<DashboardLayout lastUpdated={data.meta?.lastUpdated}>
  {data.meta ? (
    <Dashboard
      client:load
      manufacturers={data.manufacturers}
      discoveredMonth={data.discoveredMonth}
      fixedMonth={data.fixedMonth}
      patchLagMonth={data.patchLagMonth}
      backlogMonth={data.backlogMonth}
      discoveredYear={data.discoveredYear}
      fixedYear={data.fixedYear}
      patchLagYear={data.patchLagYear}
      backlogYear={data.backlogYear}
    />
  ) : (
    <div class="bg-vt-bg-secondary border border-vt-border rounded-lg p-12 text-center">
      <h2 class="mb-2 text-xl">No data yet</h2>
      <p class="text-vt-text-muted mb-6">
        Run <code class="text-vt-accent">npm run data:build</code> to fetch
        vulnerability data from vendor sources and generate the dashboard.
      </p>
      <p class="text-vt-text-muted text-sm">
        The data build is decoupled from the site build — run it once, then
        iterate on the website with <code class="text-vt-accent">npm run dev</code>.
      </p>
    </div>
  )}
</DashboardLayout>
